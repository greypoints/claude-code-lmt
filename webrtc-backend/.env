PORT=3000

# ====== TURN 配置（三选一，不配则仅用 STUN，同 WiFi 可用） ======

# 方式A：Metered.ca 免费 API（在线获取动态凭证）
# METERED_API_KEY=your-api-key

# 方式B：静态凭证（自建 coturn 长期凭证模式，或其他 TURN 服务商）
TURN_URL=turn:81.70.188.213:3478?transport=udp
TURN_USERNAME=webrtc
TURN_CREDENTIAL=MyPassword123

# 方式C：自建 coturn HMAC 模式（最安全，后端自动生成临时凭证）
# COTURN_SECRET=your-static-secret
# COTURN_URL=turn:your-server:3478
